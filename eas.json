{
  "cli": {
    "version": ">= 18.8.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_TMDB_API_KEY": "YOUR_TMDB_API_KEY_HERE"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_TMDB_API_KEY": "YOUR_TMDB_API_KEY_HERE"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_TMDB_API_KEY": "YOUR_TMDB_API_KEY_HERE"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
